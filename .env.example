# All variables below are validated via Pydantic Settings at startup.
# OpenRouter LLM configuration
OPENAI_API_BASE=https://openrouter.ai/api/v1
OPENAI_API_KEY=your_openrouter_key
OPENAI_MODEL_NAME=openrouter/openai/gpt-4o-mini

# Optional: Path to mock database (default: data/mock_db.json)
MOCK_DB_PATH=data/mock_db.json

# Optional: Path to SQLite claims database (default: data/claims.db)
CLAIMS_DB_PATH=data/claims.db
# Optional: PostgreSQL URL for production. If set, use PostgreSQL instead of SQLite.
# Example: postgresql://user:pass@host:5432/claims
# DATABASE_URL=postgresql://user:pass@host:5432/claims
# Run alembic upgrade head on API startup when using PostgreSQL (default: true).
# Set to false to run migrations as a separate deploy step.
# RUN_MIGRATIONS_ON_STARTUP=true
# If true, delete and recreate claims DB on startup (default: false).
# WARNING: true wipes all claims on every server restart. For dev/simulation only.
FRESH_CLAIMS_DB_ON_STARTUP=false

# ============================================================================
# API SECURITY (Observability UI / Dashboard)
# ============================================================================
# When any of these are set, auth is required for all /api/* endpoints (except /api/health).
# Pass via X-API-Key header or Authorization: Bearer <key>
#
# API_KEYS: Comma-separated key:role pairs for RBAC. Roles: adjuster, supervisor, admin
# Example: sk-adj-xxx:adjuster,sk-sup-yyy:supervisor,sk-admin-zzz:admin
API_KEYS=

# CLAIMS_API_KEY: Single key (backward compat). When set and API_KEYS unset, treated as admin.
CLAIMS_API_KEY=

# JWT_SECRET: Optional. When set, accept JWT in Authorization: Bearer. Payload: sub, role.
JWT_SECRET=

# Comma-separated CORS origins for production (default: localhost only for dev)
# Example: https://app.example.com,https://dashboard.example.com
CORS_ORIGINS=

# Trust X-Forwarded-For header for client IP (default: false).
# Set to true only when deployed behind a trusted reverse proxy.
TRUST_FORWARDED_FOR=false

# Redis URL for rate limiting (optional). When set, use Redis backend for multi-instance deployments.
# Example: redis://localhost:6379/0
# REDIS_URL=redis://localhost:6379/0

# Idempotency key TTL in seconds (default: 86400 = 24h). Used for Idempotency-Key header on claim creation.
# IDEMPOTENCY_TTL_SECONDS=86400

# Optional: Path to California auto compliance JSON (default: data/california_auto_compliance.json)
CA_COMPLIANCE_PATH=data/california_auto_compliance.json

# ============================================================================
# OBSERVABILITY & TRACING CONFIGURATION
# ============================================================================

# Logging Configuration
# Format: "json" for structured logging, "human" for human-readable (default: human)
CLAIM_AGENT_LOG_FORMAT=human

# Log level: DEBUG, INFO, WARNING, ERROR (default: INFO)
CLAIM_AGENT_LOG_LEVEL=INFO

# LangSmith Tracing (https://smith.langchain.com)
# Set to "true" to enable LangSmith tracing
LANGSMITH_TRACING=false
LANGSMITH_API_KEY=your_langsmith_api_key
LANGSMITH_PROJECT=claim-agent
LANGSMITH_ENDPOINT=https://api.smith.langchain.com

# OpenTelemetry Tracing (alongside LangSmith)
# Set to "true" to enable OTLP trace export (Jaeger, Zipkin, etc.)
OTEL_TRACING=false
OTEL_SERVICE_NAME=claim-agent
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4318

# LLM Call Tracing
# Enable/disable LLM call tracing (default: true)
CLAIM_AGENT_TRACE_LLM=true

# Enable/disable tool call tracing (default: true)
CLAIM_AGENT_TRACE_TOOLS=true

# Log full prompts sent to LLM (may contain PII, default: false)
CLAIM_AGENT_LOG_PROMPTS=false

# Log full LLM responses (default: false)
CLAIM_AGENT_LOG_RESPONSES=false

# Mask PII (policy_number, vin) in log output (default: true for production)
# Set to false for local development/debugging
CLAIM_AGENT_MASK_PII=true

# ============================================================================
# PRIVACY / DATA PROTECTION
# ============================================================================
# When true, minimize claim data sent to LLM prompts (allowlists, PII masking). Set false for debugging.
LLM_DATA_MINIMIZATION=true
# DSAR: require claim_id or policy_number+vin for verification (default: true). Set false to allow email-only lookup.
DSAR_VERIFICATION_REQUIRED=true
# DSAR deletion: skip claims with litigation_hold when true (default: true). Set false to anonymize regardless.
LITIGATION_HOLD_BLOCKS_DELETION=true

# ============================================================================
# DATA RETENTION
# ============================================================================
# Retention period in years for claims (default: 5, from CA compliance ECR-003)
# Override with RETENTION_PERIOD_YEARS. Run: claim-agent retention-enforce
RETENTION_PERIOD_YEARS=
# Years after archived_at before retention purge (default: 2). Run: claim-agent retention-purge
RETENTION_PURGE_AFTER_ARCHIVE_YEARS=
# State-specific retention: data/state_retention_periods.json (per-state years)
# STATE_RETENTION_PATH=

# ============================================================================
# ROUTER CLASSIFICATION
# ============================================================================
# Confidence threshold below which router output triggers escalation (0.0-1.0, default: 0.7)
ROUTER_CONFIDENCE_THRESHOLD=0.7
# When true, run optional validation LLM call before escalating low-confidence claims
ROUTER_VALIDATION_ENABLED=false
# DEPRECATED: Use ESCALATION_SLA_HOURS_* instead. Low-confidence escalations use ESCALATION_SLA_HOURS_MEDIUM.
# ROUTER_ESCALATION_SLA_HOURS=48

# ============================================================================
# FNOL COVERAGE VERIFICATION
# ============================================================================
# Enable coverage verification before routing (default: true)
COVERAGE_ENABLED=true
# Deny when deductible exceeds estimated damage (default: false)
COVERAGE_DENY_WHEN_DEDUCTIBLE_EXCEEDS_DAMAGE=false

# ============================================================================
# DUPLICATE DETECTION
# ============================================================================
# Similarity score threshold for standard claims (default: 40)
DUPLICATE_SIMILARITY_THRESHOLD=40
# Similarity score threshold for high-value claims (default: 60)
DUPLICATE_SIMILARITY_THRESHOLD_HIGH_VALUE=60
# Incident date window in days for duplicate matching (default: 3)
DUPLICATE_DAYS_WINDOW=3

# ============================================================================
# HIGH-VALUE CLAIM THRESHOLDS
# ============================================================================
# Estimated damage above which claim is high-value (default: 25000)
HIGH_VALUE_DAMAGE_THRESHOLD=25000
# Vehicle value above which claim is high-value (default: 50000)
HIGH_VALUE_VEHICLE_THRESHOLD=50000

# ============================================================================
# PRE-ROUTING FRAUD
# ============================================================================
# Damage-to-value ratio above which pre-routing fraud check runs (default: 0.9)
PRE_ROUTING_FRAUD_DAMAGE_RATIO=0.9

# ============================================================================
# ESCALATION (HITL) CONFIGURATION
# ============================================================================
# Confidence threshold below which claim is escalated (0.0-1.0, default: 0.7)
ESCALATION_CONFIDENCE_THRESHOLD=0.7
# Estimated damage or payout above which claim is escalated (default: 10000)
ESCALATION_HIGH_VALUE_THRESHOLD=10000
# Similarity score range (low,high) that triggers ambiguous_similarity (default: 50,80)
ESCALATION_SIMILARITY_AMBIGUOUS_RANGE=50,80
# Damage vs vehicle value ratio for fraud indicator (default: 0.9)
ESCALATION_FRAUD_DAMAGE_VS_VALUE_RATIO=0.9
# Days to look back for multiple claims on same VIN (default: 90)
ESCALATION_VIN_CLAIMS_DAYS=90
# Confidence decrement per low-confidence pattern in router output (default: 0.15)
ESCALATION_CONFIDENCE_DECREMENT_PER_PATTERN=0.15
# Min word overlap between incident and damage description (default: 0.1)
ESCALATION_DESCRIPTION_OVERLAP_THRESHOLD=0.1
# Use agent for escalation decision (default: true). If false, uses rule-based evaluate_escalation.
ESCALATION_USE_AGENT=true

# Escalation SLA hours by priority (used for mid-workflow escalations)
ESCALATION_SLA_HOURS_CRITICAL=24
ESCALATION_SLA_HOURS_HIGH=24
ESCALATION_SLA_HOURS_MEDIUM=48
ESCALATION_SLA_HOURS_LOW=72

# ============================================================================
# FRAUD DETECTION CONFIGURATION
# ============================================================================
FRAUD_MULTIPLE_CLAIMS_DAYS=90
FRAUD_MULTIPLE_CLAIMS_THRESHOLD=2
FRAUD_KEYWORD_SCORE=20
FRAUD_MULTIPLE_CLAIMS_SCORE=25
FRAUD_TIMING_ANOMALY_SCORE=15
FRAUD_DAMAGE_MISMATCH_SCORE=20
FRAUD_HIGH_RISK_THRESHOLD=50
FRAUD_MEDIUM_RISK_THRESHOLD=30
FRAUD_CRITICAL_RISK_THRESHOLD=75
FRAUD_CRITICAL_INDICATOR_COUNT=5
FRAUD_VELOCITY_WINDOW_DAYS=30
FRAUD_VELOCITY_CLAIM_THRESHOLD=2
FRAUD_VELOCITY_SCORE=20
FRAUD_GEOGRAPHIC_ANOMALY_SCORE=15
FRAUD_PROVIDER_RING_THRESHOLD=2
FRAUD_PROVIDER_RING_SCORE=20
FRAUD_GRAPH_MAX_DEPTH=2
FRAUD_GRAPH_MAX_NODES=100
FRAUD_GRAPH_CLUSTER_SCORE=25
FRAUD_GRAPH_HIGH_RISK_LINK_THRESHOLD=2
FRAUD_GRAPH_HIGH_RISK_SCORE=20
FRAUD_STAGED_PATTERN_SCORE=20
FRAUD_CLAIMSEARCH_MATCH_THRESHOLD=2
FRAUD_CLAIMSEARCH_MATCH_SCORE=25
FRAUD_PHOTO_EXIF_ANOMALY_SCORE=10

# ============================================================================
# RESERVE MANAGEMENT
# ============================================================================
# Adjuster authority limit in dollars (default: 10000)
RESERVE_ADJUSTER_LIMIT=
# Supervisor/admin authority limit in dollars (default: 50000)
RESERVE_SUPERVISOR_LIMIT=
# Set initial reserve from estimated_damage at FNOL when true (default: true)
RESERVE_INITIAL_RESERVE_FROM_ESTIMATED_DAMAGE=
# Reserve adequacy when moving to closed/settled: off | block | warn (default: warn)
# block = inadequate reserve rejects transition unless supervisor+ uses skip_adequacy_check on update_claim_status
RESERVE_CLOSE_SETTLE_ADEQUACY_GATE=

# ============================================================================
# PAYMENT AUTHORITY LIMITS
# ============================================================================
# Adjuster payment authority limit in dollars (default: 5000)
PAYMENT_ADJUSTER_LIMIT=
# Supervisor payment authority limit in dollars (default: 25000)
PAYMENT_SUPERVISOR_LIMIT=
# Executive/admin payment authority limit in dollars (default: 100000)
PAYMENT_EXECUTIVE_LIMIT=
# When true, main workflow creates one authorized claim_payments row from extracted_payout (idempotent per workflow_run_id).
# Do not combine with settlement agents calling record_claim_payment for the same payout (double ledger).
PAYMENT_AUTO_RECORD_FROM_SETTLEMENT=

# ============================================================================
# VALUATION & PARTIAL LOSS
# ============================================================================
VALUATION_DEFAULT_BASE_VALUE=12000
VALUATION_DEPRECIATION_PER_YEAR=500
VALUATION_MIN_VEHICLE_VALUE=2000
VALUATION_DEFAULT_DEDUCTIBLE=500
VALUATION_MIN_PAYOUT_VEHICLE_VALUE=100
PARTIAL_LOSS_THRESHOLD=0.75
PARTIAL_LOSS_LABOR_HOURS_RNI_PER_PART=1.5
PARTIAL_LOSS_LABOR_HOURS_PAINT_BODY=2.0
PARTIAL_LOSS_LABOR_HOURS_MIN=2.0

# ============================================================================
# TOKEN BUDGETS & RATE LIMITS
# ============================================================================
# Max tokens per claim before stopping (default: 150000)
CLAIM_AGENT_MAX_TOKENS_PER_CLAIM=150000
# Max LLM API calls per claim (default: 50)
CLAIM_AGENT_MAX_LLM_CALLS_PER_CLAIM=50
# Model fallback chain (comma-separated). Primary → fallback1 → fallback2 when primary fails.
# Example: gpt-4o-mini,gpt-3.5-turbo
OPENAI_FALLBACK_MODELS=
# Max concurrent background workflow tasks for async processing (default: 10)
# When exceeded, POST with ?async=true returns 503. Set 0 for unlimited.
CLAIM_AGENT_MAX_CONCURRENT_BACKGROUND_TASKS=10

# CrewAI verbose mode (default: true)
CREWAI_VERBOSE=true

# ============================================================================
# WEBHOOKS
# ============================================================================
# Outbound webhooks for claim status changes and repair authorization.
# WEBHOOK_URL: Single URL (used if WEBHOOK_URLS unset)
# WEBHOOK_URLS: Comma-separated URLs for status events
WEBHOOK_URL=
WEBHOOK_URLS=

# HMAC secret for X-Webhook-Signature. Required for POST /api/webhooks/repair-status
# (incoming shop status updates). When set, requests must include
# X-Webhook-Signature: sha256=<hex>.
WEBHOOK_SECRET=

# Max retries per delivery (default: 5)
WEBHOOK_MAX_RETRIES=5
# Enable/disable webhooks (default: true)
WEBHOOK_ENABLED=true

# Optional: Shop-specific URL for repair.authorized events
WEBHOOK_SHOP_URL=
# Optional: File path for dead-letter failed deliveries
WEBHOOK_DEAD_LETTER_PATH=

# ============================================================================
# CLAIMANT NOTIFICATIONS (optional, stub)
# ============================================================================
NOTIFICATION_EMAIL_ENABLED=false
NOTIFICATION_SMS_ENABLED=false

# ============================================================================
# DIARY / CALENDAR SYSTEM
# ============================================================================
# Auto-create diary entries at key status transitions (default: true)
DIARY_AUTO_CREATE_ON_STATUS_CHANGE=true
# Hours after overdue notification before escalating to supervisor (default: 24)
DIARY_ESCALATION_HOURS_BEFORE_SUPERVISOR=24

# ============================================================================
# ADAPTER BACKENDS
# ============================================================================
# Each adapter can be "mock" (default, uses mock_db.json), "stub" (raises
# NotImplementedError), or "rest" (policy only: REST PAS integration).
POLICY_ADAPTER=mock
VALUATION_ADAPTER=mock
REPAIR_SHOP_ADAPTER=mock
PARTS_ADAPTER=mock
SIU_ADAPTER=mock
CLAIM_SEARCH_ADAPTER=mock
# Fallback state for SIU fraud bureau reporting when claim/policy state is missing
SIU_DEFAULT_STATE=California
# Vision: "real" (litellm vision model) or "mock" (derive from claim context)
VISION_ADAPTER=real
# OCR: "mock" (sample structured data) or "stub" (no extraction)
OCR_ADAPTER=mock

# REST Policy Adapter (POLICY_ADAPTER=rest)
# POLICY_REST_BASE_URL=https://pas.example.com/api/v1
# POLICY_REST_AUTH_HEADER=Authorization
# POLICY_REST_AUTH_VALUE=Bearer sk-your-pas-token
# POLICY_REST_PATH_TEMPLATE=/policies/{policy_number}
# POLICY_REST_RESPONSE_KEY=
# POLICY_REST_TIMEOUT=15

# ============================================================================
# CHAT AGENT
# ============================================================================
# Max tool-call rounds per conversation turn (default: 5)
CHAT_MAX_TOOL_ROUNDS=5
# Max messages to send to LLM per turn (default: 50)
CHAT_MAX_MESSAGE_HISTORY=50
# Custom system prompt (empty = use built-in default)
CHAT_SYSTEM_PROMPT_OVERRIDE=

# ============================================================================
# CLAIMANT PORTAL
# ============================================================================
# Enable claimant self-service portal (default: true)
CLAIMANT_PORTAL_ENABLED=true
# Verification mode: token, policy_vin, or email
CLAIMANT_VERIFICATION_MODE=policy_vin
# Token validity in days when using token mode (default: 90)
CLAIM_ACCESS_TOKEN_EXPIRY_DAYS=90

# ============================================================================
# MOCK CREW (testing only)
# ============================================================================
# Enable Mock Crew to simulate external interactions (claimant, vision, etc.)
MOCK_CREW_ENABLED=false
# Optional seed for reproducible mock outputs
MOCK_CREW_SEED=

# Mock image generator (OpenRouter)
MOCK_IMAGE_GENERATOR_ENABLED=false
# OpenRouter model for image generation (e.g. google/gemini-2.0-flash-exp)
MOCK_IMAGE_MODEL=google/gemini-2.0-flash-exp
# Vision analysis: "claim_context" (derive from claim) or "openrouter" (real API)
MOCK_IMAGE_VISION_ANALYSIS_SOURCE=claim_context
