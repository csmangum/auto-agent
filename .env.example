# All variables below are validated via Pydantic Settings at startup.
# OpenRouter LLM configuration
OPENAI_API_BASE=https://openrouter.ai/api/v1
OPENAI_API_KEY=your_openrouter_key
OPENAI_MODEL_NAME=openrouter/openai/gpt-4o-mini

# Optional: Path to mock database (default: data/mock_db.json)
MOCK_DB_PATH=data/mock_db.json

# Optional: Path to SQLite claims database (default: data/claims.db)
# NOTE: SQLite is suitable for local development and single-process testing ONLY.
#       It does NOT support concurrent writes (multiple workers cause "database is
#       locked" errors), has no replication, no high-availability, and no
#       point-in-time recovery. For any pilot or production deployment, set
#       DATABASE_URL to a PostgreSQL connection string instead (see below).
CLAIMS_DB_PATH=data/claims.db

# *** REQUIRED for production / pilot deployments ***
# PostgreSQL URL. When set, the app uses PostgreSQL with connection pooling
# instead of SQLite. Run 'alembic upgrade head' once before starting the server
# (or leave RUN_MIGRATIONS_ON_STARTUP=true to apply migrations automatically).
# Example: postgresql://user:pass@host:5432/claims
# DATABASE_URL=postgresql://user:pass@host:5432/claims

# Optional: PostgreSQL read-replica URL for high availability. When set alongside DATABASE_URL,
# read-heavy queries are routed to this replica; writes always go to the primary.
# Example: postgresql://user:pass@replica-host:5432/claims
# READ_REPLICA_DATABASE_URL=postgresql://user:pass@replica-host:5432/claims
# Optional: SQLAlchemy pool tuning when using PostgreSQL (defaults: 5 and 10).
# Applies to both primary and replica engines.
# DB_POOL_SIZE=5
# DB_MAX_OVERFLOW=10
# Run alembic upgrade head on API startup when using PostgreSQL (default: true).
# Set to false to run migrations as a separate deploy step.
# RUN_MIGRATIONS_ON_STARTUP=true
# If true, delete and recreate claims DB on startup (default: false).
# WARNING: true wipes all claims on every server restart. For dev/simulation only.
FRESH_CLAIMS_DB_ON_STARTUP=false

# ============================================================================
# API SECURITY (Observability UI / Dashboard)
# ============================================================================
# Deployment environment. Controls whether the server enforces authentication at startup.
# Allowed values: development (default), dev, test, testing, production, staging, etc.
# When set to any value other than dev/development/test/testing, the server refuses to
# start unless at least one auth mechanism (API_KEYS, CLAIMS_API_KEY, or JWT_SECRET) is
# configured — preventing anonymous admin access in production.
# Prefer CLAIM_AGENT_ENVIRONMENT (namespaced). ENVIRONMENT is still read as a fallback.
# CLAIM_AGENT_ENVIRONMENT=development

# When any of these are set, auth is required for all /api/* endpoints (except /api/health).
# Pass via X-API-Key header or Authorization: Bearer <key>
#
# API_KEYS: Comma-separated key:role or key:role:user_id for RBAC. Roles: adjuster, supervisor, admin, executive
# Optional third segment binds API identity to user id (align with claims.assignee for adjuster scoping).
# Example: sk-adj-xxx:adjuster,sk-sup-yyy:supervisor,sk-adj2:adjuster:uuid-of-adjuster
API_KEYS=

# CLAIMS_API_KEY: Single key (backward compat). When set and API_KEYS unset, treated as admin.
CLAIMS_API_KEY=

# JWT_SECRET: When set, accept access JWT in Authorization: Bearer (sub, role, token_use=access).
# Required for POST /api/auth/login and /api/auth/refresh.
JWT_SECRET=

# Access JWT and opaque refresh token lifetimes (seconds).
# JWT_ACCESS_TTL_SECONDS=900
# JWT_REFRESH_TTL_SECONDS=604800

# Comma-separated CORS origins for production (default: localhost only for dev)
# Example: https://app.example.com,https://dashboard.example.com
CORS_ORIGINS=

# Comma-separated HTTP methods allowed by CORS (default: GET,HEAD,POST,PUT,PATCH,DELETE)
# CORS_METHODS=GET,HEAD,POST,PUT,PATCH,DELETE

# Comma-separated request headers allowed by CORS. If set, this REPLACES the built-in
# default list (it is not merged). Default headers:
#   Authorization, Content-Type, Idempotency-Key, X-API-Key, X-Claim-Access-Token,
#   X-Claim-Id, X-Email, X-Policy-Number, X-Portal-Token, X-Repair-Shop-Access-Token,
#   X-Third-Party-Access-Token, X-Vin, X-Webhook-Signature
# CORS_HEADERS=Authorization,Content-Type,Idempotency-Key,X-API-Key

# Trust X-Forwarded-For header for client IP (default: false).
# Set to true only when deployed behind a trusted reverse proxy.
TRUST_FORWARDED_FOR=false

# HTTPS / TLS enforcement (default: false).
# When true, the API adds Strict-Transport-Security (HSTS) headers and redirects
# HTTP requests to HTTPS using X-Forwarded-Proto only if TRUST_FORWARDED_FOR=true
# (trusted proxy). Enable ONLY behind a TLS-terminating proxy (e.g. nginx, AWS ALB).
# See nginx/nginx.conf and docker-compose.yml (--profile tls) for a ready-to-use setup.
ENFORCE_HTTPS=false

# HSTS max-age in seconds (default: 31536000 = 1 year).
# Only used when ENFORCE_HTTPS=true.
# HSTS_MAX_AGE=31536000

# Append 'includeSubDomains' to the HSTS header (default: true).
# Only used when ENFORCE_HTTPS=true.
# HSTS_INCLUDE_SUBDOMAINS=true

# HSTS preload directive (default: false). Only append when you intend to submit the
# site to the browser preload list (hstspreload.org).
# HSTS_PRELOAD=false

# Redis URL for rate limiting (optional). When set, use Redis backend for multi-instance deployments.
# Example: redis://localhost:6379/0
# REDIS_URL=redis://localhost:6379/0

# Idempotency key TTL in seconds (default: 86400 = 24h). Used for Idempotency-Key header on claim creation.
# IDEMPOTENCY_TTL_SECONDS=86400

# Request body size limits (DoS protection)
# Maximum body size in MB for non-file-upload endpoints (default: 10 MB).
# MAX_REQUEST_BODY_SIZE_MB=10
# Maximum body size in MB for multipart/form-data file-upload endpoints (default: 100 MB).
# MAX_UPLOAD_BODY_SIZE_MB=100

# Maximum size in MB for a single uploaded file on claims API and claimant/repair/
# third-party portal document uploads (default: 50 MB).
# MAX_UPLOAD_FILE_SIZE_MB=50

# ============================================================================
# OPTIONAL IN-PROCESS SCHEDULER
# ============================================================================
# Enable built-in scheduler (default false). If false, use external cron.
# Each process runs its own scheduler: with multiple API workers/replicas, set false
# on API and use external cron or a single dedicated `claim-agent run-scheduler`.
SCHEDULER_ENABLED=false
# Timezone for scheduler cron expressions
SCHEDULER_TIMEZONE=UTC
# Daily UCSPA deadline sweep (default 09:00 every day)
SCHEDULER_UCSPA_DEADLINE_CHECK_CRON=0 9 * * *
# Hourly diary escalation sweep
SCHEDULER_DIARY_ESCALATE_CRON=0 * * * *
# UCSPA lookahead window used by scheduler (days)
SCHEDULER_UCSPA_DAYS_AHEAD=3
# ERP inbound-event polling schedule (default: every 15 minutes)
SCHEDULER_ERP_POLL_CRON=*/15 * * * *

# Optional: Path to California auto compliance JSON (default: data/california_auto_compliance.json)
CA_COMPLIANCE_PATH=data/california_auto_compliance.json

# ============================================================================
# OBSERVABILITY & TRACING CONFIGURATION
# ============================================================================

# Logging Configuration
# Format: "json" for structured logging, "human" for human-readable (default: human)
CLAIM_AGENT_LOG_FORMAT=human

# Log level: DEBUG, INFO, WARNING, ERROR (default: INFO)
CLAIM_AGENT_LOG_LEVEL=INFO

# LangSmith Tracing (https://smith.langchain.com)
# Set to "true" to enable LangSmith tracing
LANGSMITH_TRACING=false
LANGSMITH_API_KEY=your_langsmith_api_key
LANGSMITH_PROJECT=claim-agent
LANGSMITH_ENDPOINT=https://api.smith.langchain.com

# OpenTelemetry Tracing (alongside LangSmith)
# Set to "true" to enable OTLP trace export (Jaeger, Zipkin, etc.)
OTEL_TRACING=false
OTEL_SERVICE_NAME=claim-agent
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4318

# LLM Call Tracing
# Enable/disable LLM call tracing (default: true)
CLAIM_AGENT_TRACE_LLM=true

# Enable/disable tool call tracing (default: true)
CLAIM_AGENT_TRACE_TOOLS=true

# Log full prompts sent to LLM (may contain PII, default: false)
CLAIM_AGENT_LOG_PROMPTS=false

# Log full LLM responses (default: false)
CLAIM_AGENT_LOG_RESPONSES=false

# Mask PII (policy_number, vin) in log output (default: true for production)
# Set to false for local development/debugging
CLAIM_AGENT_MASK_PII=true

# ============================================================================
# PRIVACY / DATA PROTECTION
# ============================================================================
# When true, minimize claim data sent to LLM prompts (allowlists, PII masking). Set false for debugging.
LLM_DATA_MINIMIZATION=true

# ---- Prompt caching --------------------------------------------------------
# Enable LiteLLM in-process prompt cache. When true, identical prompts are served
# from memory without a provider round-trip. Best for repeated identical system
# prompts or RAG context blocks. Cache is per-process (not shared across workers).
# Caveat: do not cache calls whose prompts contain claimant-specific PII.
LLM_CACHE_ENABLED=false
# Optional integer seed for deterministic LiteLLM cache keys. Leave blank (default)
# to use provider-assigned cache keys.
# LLM_CACHE_SEED=
# Enable the Anthropic server-side prompt-caching beta header
# (anthropic-beta: prompt-caching-2024-07-31). Effective only with Anthropic models
# (direct or via OpenRouter). Reduces cost/latency on repeated identical system
# prompts ≥1024 tokens. Cache TTL ~5 minutes on the provider side.
# Caveat: do not include claimant-specific PII in sections intended to be cached.
LLM_ANTHROPIC_PROMPT_CACHE=false
# DSAR: require claim_id or policy_number+vin for verification (default: true). Set false to allow email-only lookup.
DSAR_VERIFICATION_REQUIRED=true
# DSAR deletion: skip claims with litigation_hold when true (default: true). Set false to anonymize regardless.
LITIGATION_HOLD_BLOCKS_DELETION=true

# Cross-border data transfer controls (GDPR Art. 44+ / CCPA):
# Primary data region for this deployment: 'us', 'eu', or 'other'.
# Determines the source jurisdiction when loss_state is absent.
DATA_REGION=us
# Policy for cross-border transfers: 'allow' (log only), 'audit' (log + warn), 'restrict' (block lacking mechanism).
CROSS_BORDER_POLICY=audit
# Legal mechanism for LLM API transfers: scc | adequacy_decision | explicit_consent | bcr | legitimate_interests | none
# Set to 'scc' when operating under GDPR and using a US LLM provider with SCCs executed.
LLM_TRANSFER_MECHANISM=scc

# OTP-based self-service DSAR verification:
# Set OTP_ENABLED=true to allow claimants to verify their identity via email/SMS OTP.
# OTP_ENABLED=false
# OTP_PEPPER: server-side secret (pepper) for HMAC-keying OTP hashes. Set to a long
# random string in production to prevent offline brute-force attacks if the DB is
# compromised. Falls back to JWT_SECRET when not set.
# OTP_PEPPER=change-me-to-a-long-random-string-in-production
# OTP_TTL_MINUTES=15
# OTP_MAX_ATTEMPTS=5
# OTP_RATE_LIMIT_WINDOW_MINUTES=60
# OTP_RATE_LIMIT_MAX_REQUESTS=5
# OTP_CODE_LENGTH=6

# Audit log state redaction (requires migration 049):
# When true, details / before_state / after_state JSON fields in claim_audit_log are
# redacted (PII keys replaced with [REDACTED]) during retention purge — not DSAR
# (DSAR uses DSAR_AUDIT_LOG_POLICY).
# AUDIT_LOG_STATE_REDACTION_ENABLED=false
# Policy for claim_audit_log entries during DSAR deletion:
#   preserve (default): keep audit rows unchanged for legal/regulatory compliance.
#   redact: scrub PII values from details/before_state/after_state JSON while retaining action metadata.
#   delete: remove all audit rows (irreversible; requires compliance sign-off).
# DSAR_AUDIT_LOG_POLICY=preserve

# ============================================================================
# DATA RETENTION
# ============================================================================
# Retention period in years for claims (default: 5, from CA compliance ECR-003)
# Override with RETENTION_PERIOD_YEARS. Run: claim-agent retention-enforce
RETENTION_PERIOD_YEARS=
# Years after archived_at before retention purge (default: 2). Run: claim-agent retention-purge
RETENTION_PURGE_AFTER_ARCHIVE_YEARS=
# Calendar years after claim purged_at before audit rows are eligible for export/purge (unset = no eligibility counts)
AUDIT_LOG_RETENTION_YEARS_AFTER_PURGE=
# Set true only after compliance approval to allow claim-agent audit-log-purge deletes
AUDIT_LOG_PURGE_ENABLED=false
# State-specific retention: data/state_retention_periods.json (per-state years)
# STATE_RETENTION_PATH=

# ============================================================================
# DATABASE BACKUPS — scripts/backup_postgres.py
# ============================================================================
# Ops/scheduling convention: whether backups are expected to run (default: false).
# Does not invoke pg_dump by itself; run scripts/backup_postgres.py (e.g. cron/systemd).
# No effect on SQLite deployments.
BACKUP_ENABLED=false
# Local directory where dump files are written (default: data/backups).
# BACKUP_DIR=data/backups
# Number of days to retain local backup files before rotation (default: 14).
# BACKUP_RETENTION_DAYS=14
# Compress backups using pg_dump custom format -Fc (default: true).
# Set to false for plain-SQL dumps (larger, human-readable).
# BACKUP_COMPRESS=true
# Optional S3 bucket to upload backups. Leave empty to keep backups local only.
# BACKUP_S3_BUCKET=
# Key prefix inside the S3 bucket (default: postgres-backups).
# BACKUP_S3_PREFIX=postgres-backups
# Optional S3-compatible endpoint URL (e.g. MinIO). Leave empty for AWS S3.
# BACKUP_S3_ENDPOINT=
# Path to pg_dump binary. Default: searches PATH.
# BACKUP_PG_DUMP_PATH=pg_dump
# Path to pg_restore binary. Default: searches PATH.
# BACKUP_PG_RESTORE_PATH=pg_restore
# Path to psql binary (used by restore script). Default: searches PATH.
# BACKUP_PG_PSQL_PATH=psql
# Subprocess timeouts (seconds) for backup/restore scripts.
# BACKUP_PG_DUMP_TIMEOUT=3600
# BACKUP_PG_RESTORE_TIMEOUT=3600
# BACKUP_PG_SMOKE_TIMEOUT=60
# BACKUP_ALEMBIC_TIMEOUT=600

# ============================================================================
# COLD-STORAGE EXPORT (S3 / Glacier) — retention-export CLI & --export-before-purge
# ============================================================================
# Enable the export pipeline (default: false). Must be true to run retention-export.
RETENTION_EXPORT_ENABLED=false
# S3 bucket for cold-storage manifests. Required when enabled.
RETENTION_EXPORT_S3_BUCKET=
# Key prefix inside the export bucket (default: retention-exports)
# RETENTION_EXPORT_S3_PREFIX=retention-exports
# Optional S3-compatible endpoint (MinIO, etc.)
# RETENTION_EXPORT_S3_ENDPOINT=
# S3 storage class (default: GLACIER_IR). Options: GLACIER_IR, GLACIER, STANDARD_IA.
# RETENTION_EXPORT_S3_STORAGE_CLASS=GLACIER_IR
# Server-side encryption: AES256 (default) or aws:kms
# RETENTION_EXPORT_ENCRYPTION=AES256
# KMS key ARN or alias when RETENTION_EXPORT_ENCRYPTION=aws:kms
# RETENTION_EXPORT_KMS_KEY_ID=

# ============================================================================
# ROUTER CLASSIFICATION
# ============================================================================
# Confidence threshold below which router output triggers escalation (0.0-1.0, default: 0.7)
ROUTER_CONFIDENCE_THRESHOLD=0.7
# When true, run optional validation LLM call before escalating low-confidence claims
ROUTER_VALIDATION_ENABLED=false
# DEPRECATED: Use ESCALATION_SLA_HOURS_* instead. Low-confidence escalations use ESCALATION_SLA_HOURS_MEDIUM.
# ROUTER_ESCALATION_SLA_HOURS=48

# ============================================================================
# FNOL COVERAGE VERIFICATION
# ============================================================================
# Enable coverage verification before routing (default: true)
COVERAGE_ENABLED=true
# Deny when deductible exceeds estimated damage (default: false)
COVERAGE_DENY_WHEN_DEDUCTIBLE_EXCEEDS_DAMAGE=false

# ============================================================================
# DUPLICATE DETECTION
# ============================================================================
# Similarity score threshold for standard claims (default: 40)
DUPLICATE_SIMILARITY_THRESHOLD=40
# Similarity score threshold for high-value claims (default: 60)
DUPLICATE_SIMILARITY_THRESHOLD_HIGH_VALUE=60
# Incident date window in days for duplicate matching (default: 3)
DUPLICATE_DAYS_WINDOW=3

# ============================================================================
# HIGH-VALUE CLAIM THRESHOLDS
# ============================================================================
# Estimated damage above which claim is high-value (default: 25000)
HIGH_VALUE_DAMAGE_THRESHOLD=25000
# Vehicle value above which claim is high-value (default: 50000)
HIGH_VALUE_VEHICLE_THRESHOLD=50000

# ============================================================================
# PRE-ROUTING FRAUD
# ============================================================================
# Damage-to-value ratio above which pre-routing fraud check runs (default: 0.9)
PRE_ROUTING_FRAUD_DAMAGE_RATIO=0.9

# ============================================================================
# ESCALATION (HITL) CONFIGURATION
# ============================================================================
# Confidence threshold below which claim is escalated (0.0-1.0, default: 0.7)
ESCALATION_CONFIDENCE_THRESHOLD=0.7
# Estimated damage or payout above which claim is escalated (default: 10000)
ESCALATION_HIGH_VALUE_THRESHOLD=10000
# Similarity score range (low,high) that triggers ambiguous_similarity (default: 50,80)
ESCALATION_SIMILARITY_AMBIGUOUS_RANGE=50,80
# Damage vs vehicle value ratio for fraud indicator (default: 0.9)
ESCALATION_FRAUD_DAMAGE_VS_VALUE_RATIO=0.9
# Days to look back for multiple claims on same VIN (default: 90)
ESCALATION_VIN_CLAIMS_DAYS=90
# Confidence decrement per low-confidence pattern in router output (default: 0.15)
ESCALATION_CONFIDENCE_DECREMENT_PER_PATTERN=0.15
# Min word overlap between incident and damage description (default: 0.1)
ESCALATION_DESCRIPTION_OVERLAP_THRESHOLD=0.1
# Use agent for escalation decision (default: true). If false, uses rule-based evaluate_escalation.
ESCALATION_USE_AGENT=true

# Escalation SLA hours by priority (used for mid-workflow escalations)
ESCALATION_SLA_HOURS_CRITICAL=24
ESCALATION_SLA_HOURS_HIGH=24
ESCALATION_SLA_HOURS_MEDIUM=48
ESCALATION_SLA_HOURS_LOW=72

# ============================================================================
# FRAUD DETECTION CONFIGURATION
# ============================================================================
FRAUD_MULTIPLE_CLAIMS_DAYS=90
FRAUD_MULTIPLE_CLAIMS_THRESHOLD=2
FRAUD_KEYWORD_SCORE=20
FRAUD_MULTIPLE_CLAIMS_SCORE=25
FRAUD_TIMING_ANOMALY_SCORE=15
FRAUD_DAMAGE_MISMATCH_SCORE=20
FRAUD_HIGH_RISK_THRESHOLD=50
FRAUD_MEDIUM_RISK_THRESHOLD=30
FRAUD_CRITICAL_RISK_THRESHOLD=75
FRAUD_CRITICAL_INDICATOR_COUNT=5
FRAUD_VELOCITY_WINDOW_DAYS=30
FRAUD_VELOCITY_CLAIM_THRESHOLD=2
FRAUD_VELOCITY_SCORE=20
FRAUD_GEOGRAPHIC_ANOMALY_SCORE=15
FRAUD_PROVIDER_RING_THRESHOLD=2
FRAUD_PROVIDER_RING_SCORE=20
FRAUD_GRAPH_MAX_DEPTH=2
FRAUD_GRAPH_MAX_NODES=100
FRAUD_GRAPH_CLUSTER_SCORE=25
FRAUD_GRAPH_HIGH_RISK_LINK_THRESHOLD=2
FRAUD_GRAPH_HIGH_RISK_SCORE=20
FRAUD_STAGED_PATTERN_SCORE=20
FRAUD_CLAIMSEARCH_MATCH_THRESHOLD=2
FRAUD_CLAIMSEARCH_MATCH_SCORE=25
FRAUD_PHOTO_EXIF_ANOMALY_SCORE=10
# Score for photo_gps_far_from_incident anomaly (defaults to same weight as FRAUD_PHOTO_EXIF_ANOMALY_SCORE)
FRAUD_PHOTO_GPS_FAR_FROM_INCIDENT_SCORE=10
# Max distance between EXIF GPS and optional incident coordinates before fraud flag (default 50)
FRAUD_PHOTO_GPS_INCIDENT_MAX_DISTANCE=50
# miles | km
FRAUD_PHOTO_GPS_INCIDENT_DISTANCE_UNIT=miles

# ============================================================================
# RESERVE MANAGEMENT
# ============================================================================
# Adjuster authority limit in dollars (default: 10000)
RESERVE_ADJUSTER_LIMIT=
# Supervisor/admin authority limit in dollars (default: 50000)
RESERVE_SUPERVISOR_LIMIT=
# Executive reserve cap in dollars (default 0 = no cap). Set positive to limit executive reserves.
RESERVE_EXECUTIVE_LIMIT=
# Set initial reserve from estimated_damage at FNOL when true (default: true)
RESERVE_INITIAL_RESERVE_FROM_ESTIMATED_DAMAGE=
# Reserve adequacy when moving to closed/settled: off | block | warn (default: warn)
# block = inadequate reserve rejects transition unless supervisor+ uses skip_adequacy_check on update_claim_status
RESERVE_CLOSE_SETTLE_ADEQUACY_GATE=

# ============================================================================
# PAYMENT AUTHORITY LIMITS
# ============================================================================
# Adjuster payment authority limit in dollars (default: 5000)
PAYMENT_ADJUSTER_LIMIT=
# Supervisor payment authority limit in dollars (default: 25000)
PAYMENT_SUPERVISOR_LIMIT=
# Executive/admin payment authority limit in dollars (default: 100000)
PAYMENT_EXECUTIVE_LIMIT=
# When true, main workflow creates one authorized claim_payments row from extracted_payout (idempotent per workflow_run_id).
# Do not combine with settlement agents calling record_claim_payment for the same payout (double ledger).
PAYMENT_AUTO_RECORD_FROM_SETTLEMENT=

# ============================================================================
# VALUATION & PARTIAL LOSS
# ============================================================================
VALUATION_DEFAULT_BASE_VALUE=12000
VALUATION_DEPRECIATION_PER_YEAR=500
VALUATION_MIN_VEHICLE_VALUE=2000
VALUATION_DEFAULT_DEDUCTIBLE=500
VALUATION_MIN_PAYOUT_VEHICLE_VALUE=100
PARTIAL_LOSS_THRESHOLD=0.75
PARTIAL_LOSS_LABOR_HOURS_RNI_PER_PART=1.5
PARTIAL_LOSS_LABOR_HOURS_PAINT_BODY=2.0
PARTIAL_LOSS_LABOR_HOURS_MIN=2.0

# ============================================================================
# TOKEN BUDGETS & RATE LIMITS
# ============================================================================
# Max tokens per claim before stopping (default: 150000)
CLAIM_AGENT_MAX_TOKENS_PER_CLAIM=150000
# Max LLM API calls per claim (default: 50)
CLAIM_AGENT_MAX_LLM_CALLS_PER_CLAIM=50
# Wall-clock timeout for run_claim_workflow() in seconds (default: 600 = 10 minutes).
# Checked only *between* workflow stages (not mid-stage); a single slow stage can exceed
# this until it finishes. Use LLM_CALL_TIMEOUT_SECONDS to cap individual LLM calls.
# When exceeded the claim is marked failed and a claim.timeout webhook is fired.
# Minimum 30 seconds.
CLAIM_WORKFLOW_TIMEOUT_SECONDS=600
# Per-LLM-call timeout in seconds (default: 120 = 2 minutes).
# Passed directly to the CrewAI LLM instance to prevent individual calls from hanging.
# Minimum 10 seconds.
LLM_CALL_TIMEOUT_SECONDS=120
# Model fallback chain (comma-separated). Primary → fallback1 → fallback2 when primary fails.
# Example: gpt-4o-mini,gpt-3.5-turbo
OPENAI_FALLBACK_MODELS=
# Budget-driven model fallback: proactively switch to the next OPENAI_FALLBACK_MODELS entry
# before hitting a hard token/call budget error (requires OPENAI_FALLBACK_MODELS to be set).
LLM_BUDGET_FALLBACK_ENABLED=false
# Fraction of MAX_TOKENS_PER_CLAIM or MAX_LLM_CALLS_PER_CLAIM that triggers budget-driven
# fallback (0.0–1.0, default: 0.9). Only active when LLM_BUDGET_FALLBACK_ENABLED=true.
LLM_BUDGET_FALLBACK_THRESHOLD=0.9
# Max concurrent background workflow tasks for async processing (default: 10)
# When exceeded, POST with ?async=true returns 503. Set 0 for unlimited.
CLAIM_AGENT_MAX_CONCURRENT_BACKGROUND_TASKS=10

# CrewAI verbose mode (default: true)
CREWAI_VERBOSE=true

# ============================================================================
# WEBHOOKS
# ============================================================================
# Outbound webhooks for claim status changes and repair authorization.
# WEBHOOK_URL: Single URL (used if WEBHOOK_URLS unset)
# WEBHOOK_URLS: Comma-separated URLs for status events
WEBHOOK_URL=
WEBHOOK_URLS=

# HMAC secret for X-Webhook-Signature. Required for POST /api/webhooks/repair-status
# (incoming shop status updates). When set, requests must include
# X-Webhook-Signature: sha256=<hex>.
WEBHOOK_SECRET=

# Max retries per delivery (default: 5)
WEBHOOK_MAX_RETRIES=5
# Enable/disable webhooks (default: true)
WEBHOOK_ENABLED=true

# Optional: Shop-specific URL for repair.authorized events
WEBHOOK_SHOP_URL=
# Optional: File path for dead-letter failed deliveries
WEBHOOK_DEAD_LETTER_PATH=

# Optional LLM spend alert: fires once per process when in-memory total_cost_usd
# first exceeds threshold. Leave threshold empty to disable.
LLM_COST_ALERT_THRESHOLD_USD=
# Optional webhook URL to receive the threshold-crossed payload (JSON).
LLM_COST_ALERT_WEBHOOK_URL=

# ============================================================================
# CLAIMANT NOTIFICATIONS (optional)
# ============================================================================
NOTIFICATION_EMAIL_ENABLED=false
NOTIFICATION_SMS_ENABLED=false
# SendGrid (email)
SENDGRID_API_KEY=
SENDGRID_FROM_EMAIL=
# Twilio (SMS)
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_PHONE=

# ============================================================================
# DIARY / CALENDAR SYSTEM
# ============================================================================
# Auto-create diary entries at key status transitions (default: true)
DIARY_AUTO_CREATE_ON_STATUS_CHANGE=true
# Hours after overdue notification before escalating to supervisor (default: 24)
DIARY_ESCALATION_HOURS_BEFORE_SUPERVISOR=24

# ============================================================================
# ADAPTER BACKENDS
# ============================================================================
# Each adapter can be "mock" (default, uses mock_db.json), "stub" (raises
# NotImplementedError), or "rest" (connects to a live external system).
# VALUATION_ADAPTER also accepts "ccc", "mitchell", or "audatex" for the
# REST valuation gateway (configure VALUATION_REST_* settings below).
POLICY_ADAPTER=mock
VALUATION_ADAPTER=mock
# REST valuation gateway (ccc | mitchell | audatex):
# VALUATION_REST_BASE_URL=https://valuation-gateway.example.com
# VALUATION_REST_PATH_TEMPLATE=/api/v1/vehicle-valuation?vin={vin}&year={year}&make={make}&model={model}
# VALUATION_REST_AUTH_HEADER=Authorization
# VALUATION_REST_AUTH_VALUE=
# VALUATION_REST_RESPONSE_KEY=data
# VALUATION_REST_TIMEOUT=15
# Repair shop network adapter: mock | stub | rest
REPAIR_SHOP_ADAPTER=mock
# Parts catalog adapter: mock | stub | rest
PARTS_ADAPTER=mock
# SIU case management adapter: mock | stub | rest
SIU_ADAPTER=mock
# State DOI fraud bureau filing adapter: mock | stub | rest
STATE_BUREAU_ADAPTER=mock
# Cross-carrier NICB/ISO ClaimSearch adapter: mock | stub | rest
CLAIM_SEARCH_ADAPTER=mock
FRAUD_REPORTING_ADAPTER=mock
# NMVTIS federal total-loss / salvage reporting: mock | stub | rest
NMVTIS_ADAPTER=mock
# Gap (loan/lease) carrier after total loss: mock | stub | rest
GAP_INSURANCE_ADAPTER=mock
# Fallback state for SIU fraud bureau reporting when claim/policy state is missing
SIU_DEFAULT_STATE=California
# Seconds to sleep between SIU/fraud adapter retries on transient errors (default: exponential 1, 2, ...).
# Tests use 0 for speed; production may leave unset.
# CLAIM_AGENT_SIU_ADAPTER_RETRY_SLEEP_SEC=0
# Vision: "real" (litellm vision model) or "mock" (derive from claim context)
VISION_ADAPTER=real
# OCR: mock | stub | rest
OCR_ADAPTER=mock
# CMS / Medicare Section 111 eligibility: mock | stub | rest
CMS_ADAPTER=mock
# ERP / shop management system adapter: mock | stub | rest
# mock = in-memory (records pushes, returns seeded events); rest = live ERP API
ERP_ADAPTER=mock
# Reverse-image / stock-photo fraud detection: mock | stub | rest
# Set to "stub" or leave "mock" when no external provider key is available.
REVERSE_IMAGE_ADAPTER=mock
# Medical records adapter (bodily injury claims): mock | stub | rest
# IMPORTANT: "mock" returns fabricated data -- do NOT use in production for BI claims.
# Set to "rest" with MEDICAL_RECORDS_REST_BASE_URL to connect to a real HIE or
# provider portal. All returned data is PHI; handle per HIPAA minimum-necessary.
MEDICAL_RECORDS_ADAPTER=mock

# REST Policy Adapter (POLICY_ADAPTER=rest)
# POLICY_REST_BASE_URL=https://pas.example.com/api/v1
# POLICY_REST_AUTH_HEADER=Authorization
# POLICY_REST_AUTH_VALUE=Bearer sk-your-pas-token
# POLICY_REST_PATH_TEMPLATE=/policies/{policy_number}
# POLICY_REST_RESPONSE_KEY=
# POLICY_REST_TIMEOUT=15

# REST Fraud Reporting Adapter (FRAUD_REPORTING_ADAPTER=rest)
# FRAUD_REPORTING_REST_BASE_URL=https://fraud-filing.example.com/api/v1
# FRAUD_REPORTING_REST_AUTH_HEADER=Authorization
# FRAUD_REPORTING_REST_AUTH_VALUE=Bearer sk-your-fraud-token
# FRAUD_REPORTING_REST_STATE_BUREAU_PATH=/fraud/state-bureau
# FRAUD_REPORTING_REST_NICB_PATH=/fraud/nicb
# FRAUD_REPORTING_REST_NISS_PATH=/fraud/niss
# FRAUD_REPORTING_REST_RESPONSE_KEY=
# FRAUD_REPORTING_REST_TIMEOUT=15
# REST State Bureau Adapter (STATE_BUREAU_ADAPTER=rest)
# STATE_BUREAU_AUTH_HEADER=Authorization
# STATE_BUREAU_AUTH_VALUE=Bearer sk-your-state-bureau-token
# STATE_BUREAU_TIMEOUT=15
# STATE_BUREAU_CA_ENDPOINT=https://state-bureau.example.com/ca
# STATE_BUREAU_TX_ENDPOINT=https://state-bureau.example.com/tx
# STATE_BUREAU_FL_ENDPOINT=https://state-bureau.example.com/fl
# STATE_BUREAU_NY_ENDPOINT=https://state-bureau.example.com/ny
# STATE_BUREAU_GA_ENDPOINT=https://state-bureau.example.com/ga

# REST ClaimSearch Adapter (CLAIM_SEARCH_ADAPTER=rest)
# CLAIM_SEARCH_REST_BASE_URL=https://claimsearch.example.com/api/v1
# CLAIM_SEARCH_REST_AUTH_HEADER=Authorization
# CLAIM_SEARCH_REST_AUTH_VALUE=Bearer sk-your-claimsearch-token
# CLAIM_SEARCH_REST_SEARCH_PATH=/claims/search
# CLAIM_SEARCH_REST_RESPONSE_KEY=
# CLAIM_SEARCH_REST_TIMEOUT=15

# REST ERP Adapter (ERP_ADAPTER=rest)
# Connects to an external repair/shop management system for bi-directional
# repair workflow sync (e.g. Mitchell RepairCenter, CCC ONE, Solera).
# ERP_REST_BASE_URL=https://erp.example.com/api/v2
# ERP_REST_AUTH_HEADER=Authorization
# ERP_REST_AUTH_VALUE=Bearer sk-your-erp-token
# ERP_REST_TIMEOUT=15
# ERP_REST_ASSIGNMENT_PATH=/repairs/assignment
# ERP_REST_ESTIMATE_PATH=/repairs/estimate
# ERP_REST_STATUS_PATH=/repairs/status
# ERP_REST_EVENTS_PATH=/repairs/events
# ERP_REST_SHOP_ID_MAP=SHOP-001=42,SHOP-002=99   # internal_id=erp_id pairs

# REST Repair Shop Adapter (REPAIR_SHOP_ADAPTER=rest)
# REPAIR_SHOP_REST_BASE_URL=https://shops.example.com/api/v1
# REPAIR_SHOP_REST_AUTH_HEADER=Authorization
# REPAIR_SHOP_REST_AUTH_VALUE=Bearer sk-your-shop-token
# REPAIR_SHOP_REST_SHOPS_PATH=/shops
# REPAIR_SHOP_REST_SHOP_PATH_TEMPLATE=/shops/{shop_id}
# REPAIR_SHOP_REST_LABOR_PATH=/shops/labor-operations
# REPAIR_SHOP_REST_RESPONSE_KEY=
# REPAIR_SHOP_REST_TIMEOUT=15

# REST Parts Catalog Adapter (PARTS_ADAPTER=rest)
# PARTS_REST_BASE_URL=https://parts.example.com/api/v1
# PARTS_REST_AUTH_HEADER=Authorization
# PARTS_REST_AUTH_VALUE=Bearer sk-your-parts-token
# PARTS_REST_CATALOG_PATH=/parts/catalog
# PARTS_REST_RESPONSE_KEY=
# PARTS_REST_TIMEOUT=15

# REST SIU Adapter (SIU_ADAPTER=rest)
# SIU_REST_BASE_URL=https://siu.example.com/api/v1
# SIU_REST_AUTH_HEADER=Authorization
# SIU_REST_AUTH_VALUE=Bearer sk-your-siu-token
# SIU_REST_CASES_PATH=/siu/cases
# SIU_REST_NOTES_PATH_TEMPLATE=/siu/cases/{case_id}/notes
# SIU_REST_STATUS_PATH_TEMPLATE=/siu/cases/{case_id}/status
# SIU_REST_RESPONSE_KEY=
# SIU_REST_TIMEOUT=15

# REST NMVTIS Adapter (NMVTIS_ADAPTER=rest)
# NMVTIS_REST_BASE_URL=https://nmvtis-gateway.example.com/api/v1
# NMVTIS_REST_AUTH_HEADER=Authorization
# NMVTIS_REST_AUTH_VALUE=Bearer sk-your-nmvtis-token
# NMVTIS_REST_REPORT_PATH=/nmvtis/reports
# NMVTIS_REST_RESPONSE_KEY=
# NMVTIS_REST_TIMEOUT=15

# REST Gap Insurance Adapter (GAP_INSURANCE_ADAPTER=rest)
# GAP_REST_BASE_URL=https://gap-carrier.example.com/api/v1
# GAP_REST_AUTH_HEADER=Authorization
# GAP_REST_AUTH_VALUE=Bearer sk-your-gap-token
# GAP_REST_SUBMIT_PATH=/gap/claims
# GAP_REST_STATUS_PATH_TEMPLATE=/gap/claims/{gap_claim_id}
# GAP_REST_RESPONSE_KEY=
# GAP_REST_TIMEOUT=15

# REST OCR Adapter (OCR_ADAPTER=rest)
# OCR_REST_BASE_URL=https://ocr.example.com/api/v1
# OCR_REST_AUTH_HEADER=Authorization
# OCR_REST_AUTH_VALUE=Bearer sk-your-ocr-token
# OCR_REST_EXTRACT_PATH=/ocr/extract
# OCR_REST_RESPONSE_KEY=
# OCR_REST_TIMEOUT=30

# REST CMS/Medicare Reporting Adapter (CMS_ADAPTER=rest)
# CMS_REST_BASE_URL=https://cms-reporting.example.com/api/v1
# CMS_REST_AUTH_HEADER=Authorization
# CMS_REST_AUTH_VALUE=Bearer sk-your-cms-token
# CMS_REST_EVALUATE_PATH=/cms/evaluate
# CMS_REST_RESPONSE_KEY=
# CMS_REST_TIMEOUT=15

# REST Reverse-Image Adapter (REVERSE_IMAGE_ADAPTER=rest)
# Privacy: ensure images are EXIF-scrubbed before submission; review provider DPA.
# REVERSE_IMAGE_REST_BASE_URL=https://image-search.example.com/api/v1
# REVERSE_IMAGE_REST_AUTH_HEADER=Authorization
# REVERSE_IMAGE_REST_AUTH_VALUE=Bearer sk-your-reverse-image-token
# REVERSE_IMAGE_REST_MATCH_PATH=/images/match
# REVERSE_IMAGE_REST_RESPONSE_KEY=matches
# REVERSE_IMAGE_REST_TIMEOUT=30

# REST Medical Records Adapter (MEDICAL_RECORDS_ADAPTER=rest)
# Connect to an HIE or provider portal for real PHI retrieval in BI claims.
# All returned data is PHI -- ensure HIPAA compliance for access logging and transmission.
# MEDICAL_RECORDS_REST_BASE_URL=https://hie.example.com/api/v1
# MEDICAL_RECORDS_REST_AUTH_HEADER=Authorization
# MEDICAL_RECORDS_REST_AUTH_VALUE=Bearer sk-your-hie-token
# MEDICAL_RECORDS_REST_QUERY_PATH=/medical-records/query
# MEDICAL_RECORDS_REST_RESPONSE_KEY=
# MEDICAL_RECORDS_REST_TIMEOUT=30

# ============================================================================
# CHAT AGENT
# ============================================================================
# Max tool-call rounds per conversation turn (default: 5)
CHAT_MAX_TOOL_ROUNDS=5
# Max messages to send to LLM per turn (default: 50)
CHAT_MAX_MESSAGE_HISTORY=50
# Custom system prompt (empty = use built-in default)
CHAT_SYSTEM_PROMPT_OVERRIDE=

# ============================================================================
# CLAIMANT PORTAL
# ============================================================================
# Enable claimant self-service portal (default: true)
CLAIMANT_PORTAL_ENABLED=true
# Verification mode: token, policy_vin, or email
CLAIMANT_VERIFICATION_MODE=policy_vin
# Token validity in days when using token mode (default: 90)
CLAIM_ACCESS_TOKEN_EXPIRY_DAYS=90

# ============================================================================
# REPAIR SHOP PORTAL (per-claim magic tokens; /api/repair-portal)
# ============================================================================
REPAIR_SHOP_PORTAL_ENABLED=false
REPAIR_SHOP_PORTAL_TOKEN_EXPIRY_DAYS=90

# ============================================================================
# THIRD-PARTY PORTAL (counterparty / lienholder; /api/third-party-portal)
# ============================================================================
THIRD_PARTY_PORTAL_ENABLED=false
THIRD_PARTY_PORTAL_TOKEN_EXPIRY_DAYS=90

# ============================================================================
# MOCK CREW (testing only)
# ============================================================================
# Enable Mock Crew to simulate external interactions (claimant, vision, etc.)
MOCK_CREW_ENABLED=false
# Optional seed for reproducible mock outputs
MOCK_CREW_SEED=

# Mock image generator (OpenRouter)
MOCK_IMAGE_GENERATOR_ENABLED=false
# OpenRouter model for image generation (e.g. google/gemini-2.0-flash-exp)
MOCK_IMAGE_MODEL=google/gemini-2.0-flash-exp
# Vision analysis: "claim_context" (derive from claim) or "openrouter" (real API)
MOCK_IMAGE_VISION_ANALYSIS_SOURCE=claim_context

# Mock document generator (repair estimates, damage photo URLs)
MOCK_DOCUMENT_GENERATOR_ENABLED=false

# Mock Claimant: rule/template-based claimant simulation
# Enable the mock claimant (generates ClaimInput data and responds to follow-ups)
MOCK_CLAIMANT_ENABLED=false
# Response strategy: immediate (default), delayed, refuse, partial
MOCK_CLAIMANT_RESPONSE_STRATEGY=immediate

# Mock Notifier: intercept outbound notifications (active only when MOCK_CREW_ENABLED=true)
# Enable the mock notifier (suppress real email/SMS; always returns delivered=True)
MOCK_NOTIFIER_ENABLED=false
# If true, generate a mock claimant reply and queue it for tests (requires MOCK_CLAIMANT_ENABLED=true)
MOCK_NOTIFIER_AUTO_RESPOND=false

# Mock Repair Shop: intercept repair-shop follow-up notifications (active only when MOCK_CREW_ENABLED=true)
MOCK_REPAIR_SHOP_ENABLED=false
# Acknowledgment text returned by the mock repair shop
MOCK_REPAIR_SHOP_RESPONSE_TEMPLATE=Repair shop acknowledged receipt of request. Appointment will be scheduled.

# Mock Third Party: intercept demand-letter dispatch (active only when MOCK_CREW_ENABLED=true)
MOCK_THIRD_PARTY_ENABLED=false
# Simulated third-party response outcome: accept | reject | negotiate
MOCK_THIRD_PARTY_OUTCOME=accept

# Mock Webhook: capture outbound webhook payloads in-memory (active only when MOCK_CREW_ENABLED=true)
MOCK_WEBHOOK_CAPTURE_ENABLED=false

# Mock ERP capture: record outbound ERP pushes in-memory (active only when MOCK_CREW_ENABLED=true)
MOCK_ERP_CAPTURE_ENABLED=false
